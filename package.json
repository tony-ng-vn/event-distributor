{
  "name": "event-distributor",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:worktree": "node scripts/run-dev-worktree.mjs",
    "dev:port": "node scripts/resolve-dev-port.mjs",
    "dev:registry": "node scripts/worktree-dev-registry.mjs list",
    "worktree:setup": "node scripts/setup-worktree.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "check": "node scripts/check-in.mjs",
    "check:deploy": "node scripts/check-in.mjs --deploy",
    "check:full": "node scripts/check-in.mjs --full",
    "understanding:diff": "node scripts/understanding-diff.mjs",
    "understanding:index": "node scripts/understanding-index.mjs",
    "understanding:render": "node scripts/render-explainer-html.mjs",
    "understanding:serve": "node scripts/understanding-serve.mjs",
    "test:e2e": "E2E_TEST=true playwright test",
    "db:migrate": "npx @insforge/cli db migrations up --all"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.11",
    "@insforge/sdk": "^1.4.3",
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
