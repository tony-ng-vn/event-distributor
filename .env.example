# InsForge (server-only admin key)
INSFORGE_URL=
INSFORGE_API_KEY=

# Production InsForge URL — destructive test helpers refuse to run when INSFORGE_URL matches this
INSFORGE_PRODUCTION_URL=https://yy57ijjh.us-east.insforge.app

# Set true ONLY when INSFORGE_URL points at a dedicated test/dev InsForge branch — never production
# INSFORGE_ALLOW_DESTRUCTIVE_WRITES=true

# InsForge (public client config)
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Local dev: mock skips live Luma fetches
LUMA_FETCH_MODE=mock

# Optional admin override (comma-separated emails)
# ADMIN_EMAILS=

# Notifications (opt-in new-event emails)
# Public app URL used to build email CTA (?event=<id>) and unsubscribe links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Secret for signing login-free unsubscribe tokens. Set a long random value in production.
NOTIFICATION_UNSUBSCRIBE_SECRET=
# Delivery guard: real emails are sent ONLY when this is exactly "true".
# Unset / "false" runs a dry-run (logs payload, sends nothing) so dev and CI never mail the group.
NOTIFICATIONS_EMAIL_ENABLED=false
